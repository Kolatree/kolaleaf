# Generated local agent breadcrumbs. The repo-root CLAUDE.md is tracked and
# remains authoritative; nested generated copies are local workspace noise.
**/CLAUDE.md
!/CLAUDE.md

# Reference files (not source code)
*.png
*.pdf

# Allow snapshot-test reference images — these ARE source code for snapshot tests.
!ios/KolaleafTests/**/__Snapshots__/**/*.png
!ios/KolaleafWidgetsTests/**/__Snapshots__/**/*.png

# iOS / Xcode
# Note: .xcodeproj is committed so Xcode Cloud can statically introspect schemes
# (the workflow editor and Test actions require a remote-visible scheme).
# ci_scripts/ci_post_clone.sh regenerates it on CI as defense-in-depth.
# Run `cd ios && xcodegen generate` after editing project.yml and commit the diff.
ios/Kolaleaf.xcworkspace/
ios/build/
ios/DerivedData/
ios/*.xcuserstate
ios/**/xcuserdata/
ios/**/xcshareddata/IDEWorkspaceChecks.plist
ios/Pods/
ios/Podfile.lock
ios/.swiftpm/
ios/Kolaleaf/Info.plist
ios/KolaleafWidgets/Info.plist
